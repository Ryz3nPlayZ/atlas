{
  "architecture": "transformer_hybrid",
  "vocab_size": 32000,
  "model_dim": 352,
  "num_layers": 12,
  "attention_every_n": 1,
  "max_position_embeddings": 8192,
  "dropout": 0.0,
  "norm_epsilon": 1e-05,
  "mtp_horizon": 1,
  "answer_span_embeddings": false,
  "completion_adapter_dim": 0,
  "attention": {
    "window_size": 2048,
    "num_heads": 8,
    "num_kv_heads": 2,
    "dropout": 0.0,
    "use_bias": false,
    "qk_norm": true,
    "rope_base_local": 10000.0,
    "rope_base_global": 1000000.0,
    "global_latent_dim": 128
  },
  "recurrent": {
    "kind": "xlstm_bootstrap",
    "state_dim": 352,
    "expansion_factor": 2,
    "dropout": 0.0
  },
  "moe": {
    "enabled": true,
    "num_shared_experts": 1,
    "num_routed_experts": 4,
    "top_k": 2,
    "hidden_dim": 1408,
    "dropout": 0.0
  },
  "memory": {
    "enabled": false,
    "episodic_slots": 64,
    "semantic_slots": 32,
    "key_dim": 352,
    "value_dim": 352,
    "read_top_k": 4,
    "max_writes_per_chunk": 2
  },
  "arbiter": {
    "enabled": false,
    "hidden_dim": 352,
    "cost_weight": 0.05
  },
  "escalation": {
    "enabled": false,
    "uncertainty_threshold": 0.65,
    "max_deliberation_steps": 2,
    "max_tool_calls": 2
  },
  "transformer": {
    "local_layers_per_global": 5,
    "dense_hidden_dim": 1408,
    "moe_start_fraction": 0.5,
    "use_rms_norm": true,
    "use_rotary_embeddings": true
  },
  "mode_conditioning": {
    "enabled": true,
    "modes": ["general", "code", "answer"],
    "shared_experts_per_mode": 1
  }
}
